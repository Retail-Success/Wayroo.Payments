{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Environment": "dev",
  "AwsRegion": "us-east-1",
  "AspNetCoreEnvironment": "dev",
  "PaymentConfigurationTableName": "PaymentConfiguration",
  "OpenTelemetry": {
    "ServiceName": "wayroo-payments",
    "ServiceVersion": "1.0.0",
    "ExporterOtlpEndpoint": "http://localhost:4317",
    "ExporterOtlpProtocol": "grpc",
    "TracesSampler": "always_on",
    "Propagators": "xray,tracecontext,baggage"
  }
}
